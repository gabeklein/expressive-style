{
  "name": "@expressive/vite-plugin",
  "version": "0.3.2",
  "description": "Expressive JSX Vite Plugin",
  "repository": "https://github.com/gabeklein/expressive-dsl",
  "author": {
    "name": "Gabe Klein",
    "email": "gabe@expressive.dev",
    "url": "https://github.com/gabeklein"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest",
    "prebuild": "rm -rf ./dist",
    "prepublish": "npm run build"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "expressive",
    "jsx"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@babel/core": "^7.22.20",
    "@expressive/babel-preset": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.2",
    "prettier": "^2.8.8",
    "tsup": "^8.0.1",
    "vite": "^7.0.0",
    "vitest": "^1.5.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  }
}
