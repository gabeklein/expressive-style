{
  "name": "@expressive/vite-plugin",
  "version": "0.6.2",
  "description": "Expressive JSX Vite Plugin",
  "repository": "https://github.com/gabeklein/expressive-dsl",
  "author": {
    "name": "Gabe Klein",
    "email": "gabe@expressive.dev",
    "url": "https://github.com/gabeklein"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "waku dev debug",
    "test": "vitest",
    "prebuild": "rm -rf ./dist",
    "prepublish": "npm run build"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "expressive",
    "jsx"
  ],
  "type": "module",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "dependencies": {
    "@babel/core": "^7.22.20",
    "@expressive/babel-preset": "workspace:*",
    "@expressive/css": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.2",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "prettier": "^3.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.0.1",
    "vite": "^7.3.1",
    "vitest": "^1.5.0",
    "waku": "1.0.0-alpha.3"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  }
}
