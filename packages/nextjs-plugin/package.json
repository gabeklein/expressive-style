  "files": [
    "index.js",
    "dist"
  ],
  "dependencies": {
    "@expressive/webpack-plugin": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "devDependencies": {
    "@expressive/react": "^0.74.1",
    "@types/node": "^20.3.1",
    "@types/react": "^19.0.0",
    "next": "^16.1.0",
    "prettier": "^2.8.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.2.2"
  }
}
