{
  "name": "@expressive/nextjs-plugin",
  "version": "0.4.0",
  "description": "Next.js plugin for Expressive JSX",
  "repository": "https://github.com/gabeklein/expressive-dsl",
  "author": {
    "name": "Gabe Klein",
    "email": "gabe@expressive.dev",
    "url": "https://github.com/gabeklein"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts",
    "prebuild": "rm -rf ./dist",
    "dev": "next dev debug --webpack"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
