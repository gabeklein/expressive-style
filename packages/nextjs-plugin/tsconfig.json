{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "@expressive/typescript-plugin-jsx"
      }
    ]
  },
  "include": [
    "src/**/*",
    "app/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}