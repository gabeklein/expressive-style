{
  "name": "@expressive/webpack-plugin",
  "version": "0.6.0",
  "description": "Webpack plugin for Expressive JSX",
  "repository": "https://github.com/gabeklein/expressive-dsl",
  "private": true,
  "author": {
    "name": "Gabe Klein",
    "email": "gabe@expressive.dev",
    "url": "https://github.com/gabeklein"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "webpack",
    "expressive",
    "jsx"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@expressive/babel-preset": "workspace:*",
    "babel-loader": "^8.3.0",
    "webpack": "^5.91.0",
    "webpack-virtual-modules": "^0.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/preset-react": "^7.24.1",
    "@types/babel__core": "^7.20.2",
    "css-loader": "^7.0.0",
    "prettier": "^2.8.8",
    "swc-loader": "^0.2.6",
    "tsup": "^8.0.1",
    "vitest": "^1.5.0"
  }
}
