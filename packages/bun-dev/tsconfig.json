{
  "compilerOptions": {
    "baseUrl": "src",
    "outDir": "dist",
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "declaration": true,
    "esModuleInterop": true,
    "noUnusedLocals": true,
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "types": ["bun"],
    "paths": {
      "@expressive/*": ["../../*/src"]
    }
  },
  "include": ["src", "runtime"]
}
